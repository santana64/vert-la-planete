# Copier vers .env.local puis ajuster.
APP_URL=http://localhost:3000

# PostgreSQL — local, Supabase ou Neon. Exemple Docker fourni dans le README.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vert_la_planete

# Secret de signature des sessions (cookie httpOnly). Valeur longue et aléatoire.
AUTH_SECRET=change-me-with-a-long-random-string-32-chars-min

# Stripe (offres Pro). Clés de test depuis le dashboard Stripe.
# Sans ces clés, les pages fonctionnent mais la souscription Pro est désactivée.
STRIPE_SECRET_KEY=sk_test_xxx
# Pour le webhook local : `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Transfert des messages de contact vers une boîte mail (optionnel).
# Clé API https://resend.com — sans elle, les messages restent visibles en base.
RESEND_API_KEY=
CONTACT_EMAIL_TO=
